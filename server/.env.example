# Copy this file to ".env" and fill in real values.
# The .env file holds secrets and is NEVER committed to git.

# The port our server listens on
PORT=5000

# MongoDB connection string (we'll set this up in Phase 1)
# MONGODB_URI=mongodb://localhost:27017/studyify

# Secret used to sign login tokens (we'll use this in Phase 1)
# JWT_SECRET=change-me-to-a-long-random-string
