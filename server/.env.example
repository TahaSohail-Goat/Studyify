# Copy this file to ".env" and fill in real values.
# The .env file holds secrets and is NEVER committed to git.

# The port the server listens on
PORT=5000

# MongoDB connection string (local install or a MongoDB Atlas cluster)
MONGODB_URI=mongodb://localhost:27017/studify

# Secret used to sign login tokens — make this a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Resend API key for sending OTP / password-reset emails — https://resend.com
RESEND_API_KEY=re_your_api_key

# Groq API key (powers chat, summaries, quizzes) — https://console.groq.com/keys
GROQ_API_KEY=your-groq-key

# Your deployed frontend URL (set this on Render so CORS allows your Vercel app).
# Leave unset in local dev — localhost:5173 is the default.
CLIENT_ORIGIN=https://your-app.vercel.app
